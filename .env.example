# ── OnTheWay frontend configuration ─────────────────────────────────
# Copy to `.env.local` to override per-developer values (git-ignored).

# Use bundled mock data instead of the backend ('true' | 'false').
VITE_USE_MOCKS=false

# REST API origin, including the version segment.
VITE_API_BASE_URL=http://51.38.127.221:5106/api/v1

# SignalR hub origin (no path) — hubs live at /hubs/presence|chat|call.
VITE_HUB_BASE_URL=http://51.38.127.221:5106

# DEV ONLY: a captured Telegram WebApp.initData string so the real auth flow
# can be tested in a plain browser (outside Telegram). Leave empty in Telegram.
# VITE_TG_INIT_DATA=
