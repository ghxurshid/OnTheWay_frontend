{
  "name": "ontheway-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "OnTheWay — real-time ride matching (Tashkent). Layered React 19 architecture.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.{js,jsx,css}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@microsoft/signalr": "^8.0.17",
    "leaflet": "1.9.4",
    "leaflet-ant-path": "1.3.0",
    "leaflet-rotate": "^0.2.8",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "4.4.1",
    "eslint": "^9.39.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "typescript": "^5.9.3",
    "vite": "6.4.1",
    "vitest": "^2.1.9"
  }
}
