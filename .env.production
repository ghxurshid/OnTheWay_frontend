# Production build (vite build → Vercel). `.env.development` is NOT loaded by
# `vite build`, so the live backend URLs must be declared here (or as Vercel
# project env vars, which take precedence).
# Backend is behind nginx + Let's Encrypt TLS at the nip.io hostname, so these
# are https/wss — required because the Mini App is served over HTTPS.
VITE_USE_MOCKS=false
VITE_API_BASE_URL=https://51.38.127.221.nip.io/api/v1
VITE_HUB_BASE_URL=https://51.38.127.221.nip.io
